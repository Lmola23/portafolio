---
import Layout from "../layouts/Layout.astro";
import CarruselTech from "../components/CarruselTech.svelte";
import CarruselMethod from "../components/CarruselMethod.svelte";
import Project from "../components/Project.svelte";
import CarruselPrecio from "../components/CarruselPrecio.svelte";
import ProcesoDesarrollo from "../components/ProcesoDesarrollo.svelte";
import HeroPresentation from "../components/HeroPresentation.svelte";
import AboutContent from "../components/AboutContent.svelte";
import Footer from "../components/Footer.svelte";
---

<Layout>
    <!-- HERO PRESENTATION -->

    <div class="h-30"></div>
    <!-- ABOUT / NOSOTROS -->
    <AboutContent client:load />

    <!-- CAROUSEL DE TECNOLOGÍAS -->

    <div class="h-30"></div>
    <CarruselTech client:load />

    <div class="h-30"></div>
    <!-- METODOLOGÍA -->
    <section id="metodologia" class="py-20 md:py-28 lg:py-36 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto">
            <div class="max-w-3xl mx-auto text-center mb-14 md:mb-20">
                <h2
                    class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight leading-tight"
                >
                    Nuestra Metodología<br class="hidden sm:block" /> de Trabajo
                </h2>
                <p
                    class="text-base sm:text-lg md:text-xl text-white/50 leading-relaxed"
                >
                    Cada proyecto comienza entendiendo tu negocio, tus usuarios
                    y tus metas. Un buen producto digital nace de una
                    comprensión profunda.
                </p>
            </div>

            <div class="h-30"></div>
            <CarruselMethod client:load />
        </div>
    </section>

    <div class="h-30"></div>
    <!-- PROYECTOS -->
    <section id="proyectos" class="w-full">
        <Project client:load />
    </section>

    <div class="h-30"></div>
    <!-- PRECIOS -->
    <section id="precios" class="w-full">
        <CarruselPrecio client:load />
    </section>

    <div class="h-30"></div>
    <!-- PROCESO DE DESARROLLO -->
    <section id="proceso" class="w-full">
        <ProcesoDesarrollo client:load />
    </section>
    <div class="h-30"></div>

    <!-- FOOTER -->
    <Footer client:load />
</Layout>
